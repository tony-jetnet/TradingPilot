@page "/"
@using System.Threading
@using System.Net.Http.Json
@using TradingPilot.Trading
@inject HttpClient Http
@implements IDisposable

<div class="tp-dashboard">
    @if (_data == null)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
            <div class="spinner-border text-info" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @* ─── TOP BAR: Status + P&L Summary ─── *@
        <div class="tp-topbar mb-3">
            <div class="row g-2">
                <div class="col-auto">
                    <div class="tp-status-chip @(_data.HookStatus is "Streaming" or "Pipe Connected" ? "tp-chip-live" : _data.HookStatus is "Injected" or "Auth Only" ? "tp-chip-warn" : "tp-chip-off")">
                        <span class="tp-dot"></span> @_data.HookStatus
                    </div>
                </div>
                <div class="col-auto">
                    <div class="tp-status-chip tp-chip-info">
                        <i class="fas fa-brain me-1"></i>
                        @if (_data.StrategyStatus.IsLoaded)
                        {
                            <span>@_data.StrategyStatus.TotalRules rules across @_data.StrategyStatus.SymbolCount symbols</span>
                        }
                        else
                        {
                            <span>No AI rules loaded</span>
                        }
                    </div>
                </div>
                <div class="col-auto ms-auto">
                    <div class="tp-pnl-strip">
                        <span class="tp-label">Today</span>
                        <span class="@PnlClass(_data.PnlSummary.TodayPnl)">@FormatPnl(_data.PnlSummary.TodayPnl)</span>
                        <span class="tp-sep">|</span>
                        <span class="tp-label">Total</span>
                        <span class="@PnlClass(_data.PnlSummary.NetPnl)">@FormatPnl(_data.PnlSummary.NetPnl)</span>
                        <span class="tp-sep">|</span>
                        <span class="tp-label">Win Rate</span>
                        <span class="tp-val">@_data.PnlSummary.WinRate.ToString("F1")%</span>
                        <span class="tp-sep">|</span>
                        <span class="tp-label">Trades</span>
                        <span class="tp-val">@_data.PnlSummary.TotalTrades</span>
                    </div>
                </div>
            </div>
        </div>

        @* ─── STREAMING HEALTH ─── *@
        <div class="tp-health-bar mb-3">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div class="tp-health-metric">
                    <span class="tp-label">MQTT</span>
                    <span class="tp-val">@_data.StreamingHealth.TotalMqttMessages.ToString("N0")</span>
                </div>
                <div class="tp-health-metric">
                    <span class="tp-label">L2</span>
                    <span class="tp-val">@_data.StreamingHealth.L2DepthMessages.ToString("N0")</span>
                </div>
                <div class="tp-health-metric">
                    <span class="tp-label">Quotes</span>
                    <span class="tp-val">@_data.StreamingHealth.QuoteMessages.ToString("N0")</span>
                </div>
                <div class="tp-health-metric">
                    <span class="tp-label">Ticks</span>
                    <span class="tp-val">@_data.StreamingHealth.TickMessages.ToString("N0")</span>
                </div>
                <div class="tp-health-sep"></div>
                @foreach (var h in _data.SymbolHealth)
                {
                    <div class="tp-health-ticker">
                        <span class="tp-ticker-xs">@h.Ticker</span>
                        <span class="tp-health-dot @HealthDotClass(h.Status)" title="L2: @FormatAge(h.L2AgeSec) | Quote: @FormatAge(h.QuoteAgeSec) | Snap: @FormatAge(h.TickSnapshotAgeSec)"></span>
                    </div>
                }
            </div>
        </div>

        @* ─── SYMBOL GRID ─── *@
        <div class="tp-section-title">Watchlist</div>
        <div class="row g-2 mb-3">
            @foreach (var s in _data.Symbols)
            {
                <div class="tp-col-5">
                    <div class="tp-symbol-card @(s.CurrentPosition != 0 ? "tp-has-position" : "")">
                        <div class="tp-card-header">
                            <div class="tp-card-header-left">
                                <span class="tp-ticker">@s.Ticker</span>
                                @if (s.CurrentPosition != 0)
                                {
                                    <span class="tp-pos-badge @(s.CurrentPosition > 0 ? "tp-long" : "tp-short")">
                                        @(s.CurrentPosition > 0 ? "L" : "S")@Math.Abs(s.CurrentPosition)
                                    </span>
                                }
                                @if (s.LastSignalType != null)
                                {
                                    <span class="tp-signal-badge tp-signal-inline @(s.LastSignalType == "Buy" ? "tp-buy" : "tp-sell")">
                                        @s.LastSignalType
                                    </span>
                                    <span class="tp-signal-score-inline @PnlClass(s.LastSignalScore)">@s.LastSignalScore.ToString("F3")</span>
                                }
                            </div>
                            <div class="tp-card-header-right">
                                <span class="tp-price">@FormatPrice(s.Price)</span>
                                <span class="@PnlClass(s.Change) tp-change-inline">
                                    @(s.ChangePercent >= 0 ? "+" : "")@s.ChangePercent.ToString("F2")%
                                </span>
                            </div>
                        </div>
                        <div class="tp-indicator-row">
                            <div class="tp-ind">
                                <span class="tp-ind-label">RSI</span>
                                <span class="tp-ind-val @RsiClass(s.Rsi14)">@s.Rsi14.ToString("F0")</span>
                            </div>
                            <div class="tp-ind">
                                <span class="tp-ind-label">MOM</span>
                                <span class="tp-ind-val @MomClass(s.TickMomentum)">@s.TickMomentum.ToString("F2")</span>
                            </div>
                            <div class="tp-ind">
                                <span class="tp-ind-label">VWAP</span>
                                <span class="tp-ind-val @(s.Price > s.Vwap ? "tp-up" : "tp-down")">@(s.Price > s.Vwap ? "▲" : "▼")</span>
                            </div>
                            <div class="tp-ind">
                                <span class="tp-ind-label">VOL</span>
                                <span class="tp-ind-val">@FormatVolume(s.Volume)</span>
                            </div>
                            @if (s.SignalCount > 0)
                            {
                                <div class="tp-ind">
                                    <span class="tp-ind-label">SIG</span>
                                    <span class="tp-ind-val">@s.SignalCount</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ─── OPEN POSITIONS ─── *@
        @if (_data.OpenPositions.Count > 0)
        {
            <div class="tp-card mb-3">
                <div class="tp-card-title">Open Positions</div>
                <div class="table-responsive">
                    <table class="tp-table tp-positions-table">
                        <thead>
                            <tr>
                                <th>Symbol</th>
                                <th>Side</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Avg Price</th>
                                <th class="text-end">Current</th>
                                <th class="text-end">Mkt Value</th>
                                <th class="text-end">P&L</th>
                                <th class="text-end">P&L %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in _data.OpenPositions)
                            {
                                <tr>
                                    <td class="tp-ticker-sm">@p.Ticker</td>
                                    <td><span class="tp-pos-badge @(p.Side == "Long" ? "tp-long" : "tp-short")">@p.Side</span></td>
                                    <td class="text-end">@p.Quantity</td>
                                    <td class="text-end">@p.AvgPrice.ToString("F2")</td>
                                    <td class="text-end tp-live-price">@p.CurrentPrice.ToString("F2")</td>
                                    <td class="text-end">@FormatPnl(p.MarketValue)</td>
                                    <td class="text-end @PnlClass(p.UnrealizedPnl)">@FormatPnl(p.UnrealizedPnl)</td>
                                    <td class="text-end @PnlClass(p.UnrealizedPnlPercent)">@p.UnrealizedPnlPercent.ToString("F2")%</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="tp-positions-total">
                                <td colspan="5"></td>
                                <td class="text-end">@FormatPnl(_data.OpenPositions.Sum(p => p.MarketValue))</td>
                                <td class="text-end @PnlClass(_data.OpenPositions.Sum(p => p.UnrealizedPnl))">
                                    @FormatPnl(_data.OpenPositions.Sum(p => p.UnrealizedPnl))
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }

        @* ─── P&L STATS + STRATEGY RULES ─── *@
        <div class="row g-2 mb-3">
            <div class="col-lg-4">
                <div class="tp-card">
                    <div class="tp-card-title">Performance</div>
                    <div class="tp-stat-grid">
                        <div class="tp-stat">
                            <div class="tp-stat-label">Best Trade</div>
                            <div class="tp-stat-val @PnlClass(_data.PnlSummary.BestTrade)">@FormatPnl(_data.PnlSummary.BestTrade)</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Worst Trade</div>
                            <div class="tp-stat-val @PnlClass(_data.PnlSummary.WorstTrade)">@FormatPnl(_data.PnlSummary.WorstTrade)</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Avg Win</div>
                            <div class="tp-stat-val tp-up">@FormatPnl(_data.PnlSummary.AvgWin)</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Avg Loss</div>
                            <div class="tp-stat-val tp-down">@FormatPnl(_data.PnlSummary.AvgLoss)</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Wins</div>
                            <div class="tp-stat-val">@_data.PnlSummary.WinningTrades</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Losses</div>
                            <div class="tp-stat-val">@_data.PnlSummary.LosingTrades</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Expectancy</div>
                            <div class="tp-stat-val @PnlClass(_data.PnlSummary.Expectancy)" title="Avg $ per trade. Positive = edge exists.">@FormatPnl(_data.PnlSummary.Expectancy)</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Profit Factor</div>
                            <div class="tp-stat-val @(_data.PnlSummary.ProfitFactor >= 1.5m ? "tp-up" : _data.PnlSummary.ProfitFactor >= 1.0m ? "tp-muted" : "tp-down")" title="Gross profit / gross loss. Need > 1.5 to survive real costs.">@_data.PnlSummary.ProfitFactor.ToString("F2")</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Sharpe</div>
                            <div class="tp-stat-val @(_data.PnlSummary.SharpeRatio >= 2.0m ? "tp-up" : _data.PnlSummary.SharpeRatio >= 1.0m ? "tp-muted" : "tp-down")" title="Risk-adjusted return (annualized). > 1 decent, > 2 strong.">@_data.PnlSummary.SharpeRatio.ToString("F2")</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Sortino</div>
                            <div class="tp-stat-val @(_data.PnlSummary.SortinoRatio >= 2.0m ? "tp-up" : _data.PnlSummary.SortinoRatio >= 1.0m ? "tp-muted" : "tp-down")" title="Like Sharpe but only penalizes downside. Better for asymmetric strategies.">@_data.PnlSummary.SortinoRatio.ToString("F2")</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Max DD</div>
                            <div class="tp-stat-val tp-down" title="Largest peak-to-trough equity drawdown today.">@FormatPnl(_data.PnlSummary.MaxDrawdown)</div>
                        </div>
                        <div class="tp-stat">
                            <div class="tp-stat-label">Max Consec Loss</div>
                            <div class="tp-stat-val @(_data.PnlSummary.MaxConsecutiveLosses >= 5 ? "tp-down" : "tp-muted")" title="Longest consecutive losing streak.">@_data.PnlSummary.MaxConsecutiveLosses</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="tp-card">
                    <div class="tp-card-title">Today's Trades</div>
                    @if (_data.CompletedTrades.Count == 0)
                    {
                        <div class="tp-empty">No trades today</div>
                    }
                    else
                    {
                        <div class="tp-feed">
                            @foreach (var ct in _data.CompletedTrades)
                            {
                                int holdSec = (int)(ct.ExitTime - ct.EntryTime).TotalSeconds;
                                <div class="tp-feed-item tp-roundtrip">
                                    <span class="tp-rt-side @(ct.IsLong ? "tp-buy" : "tp-sell")">@(ct.IsLong ? "LONG" : "SHORT")</span>
                                    <span class="tp-rt-ticker">@ct.Ticker</span>
                                    <span class="tp-rt-qty">@ct.Quantity</span>
                                    <span class="tp-rt-prices">$@ct.EntryPrice.ToString("F2") → $@ct.ExitPrice.ToString("F2")</span>
                                    <span class="tp-rt-source">@ct.EntrySource</span>
                                    <span class="tp-rt-score @PnlClass(ct.EntryScore)">@ct.EntryScore.ToString("F2")</span>
                                    <span class="tp-rt-exit">@ExtractExitReason(ct.ExitReason)</span>
                                    <span class="tp-rt-pnl @PnlClass(ct.Pnl)">@FormatPnl(ct.Pnl)</span>
                                    <span class="tp-rt-time">@ct.ExitTime.ToLocalTime().ToString("h:mm tt")</span>
                                    <span class="tp-rt-hold">@FormatHoldTime(holdSec)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ─── AI RULES + SIGNAL FEED ─── *@
        <div class="row g-2 mb-3">
            <div class="col-lg-6">
                <div class="tp-card">
                    <div class="tp-card-title">AI Strategy Rules</div>
                    @if (_data.StrategyStatus.IsLoaded)
                    {
                        <div class="tp-meta mb-2">
                            Generated: @_data.StrategyStatus.GeneratedAt?.ToLocalTime().ToString("MMM dd, h:mm tt")
                        </div>
                        <div class="table-responsive">
                            <table class="tp-table">
                                <thead>
                                    <tr>
                                        <th>Symbol</th>
                                        <th>Rules</th>
                                        <th>Win Rate</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sr in _data.StrategyStatus.SymbolRules)
                                    {
                                        <tr>
                                            <td class="tp-ticker-sm">@sr.Ticker</td>
                                            <td>@sr.RuleCount</td>
                                            <td class="@(sr.OverallWinRate >= 0.5m ? "tp-up" : "tp-down")">@((sr.OverallWinRate * 100).ToString("F1"))%</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="tp-empty">No AI strategy rules loaded. Run nightly optimization first.</div>
                    }
                </div>
            </div>
            <div class="col-lg-6">
                <div class="tp-card">
                    <div class="tp-card-title">Signal Feed</div>
                    @if (_data.RecentSignals.Count == 0)
                    {
                        <div class="tp-empty">No signals yet</div>
                    }
                    else
                    {
                        <div class="tp-feed">
                            @foreach (var s in _data.RecentSignals.Take(20))
                            {
                                <div class="tp-feed-item">
                                    <span class="tp-feed-badge @(s.Type == "Buy" ? "tp-buy" : "tp-sell")">@s.Type</span>
                                    <span class="tp-strength @StrengthClass(s.Strength)">@s.Strength</span>
                                    <span class="tp-ticker-sm">@s.Ticker</span>
                                    <span class="tp-feed-price">@@@s.Price.ToString("F2")</span>
                                    <span class="tp-feed-score @PnlClass(s.Score)">@s.Score.ToString("F3")</span>
                                    <span class="tp-feed-reason" title="@s.Reason">@TruncateReason(s.Reason)</span>
                                    <span class="tp-feed-time">@s.Timestamp.ToLocalTime().ToString("h:mm:ss tt")</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardDto? _data;
    private Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _refreshTimer = new Timer(async _ =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _data = await Http.GetFromJsonAsync<DashboardDto>("/api/app/dashboard");
        }
        catch { }
    }

    private static string FormatPnl(decimal value) =>
        value >= 0 ? $"${value:N2}" : $"-${Math.Abs(value):N2}";

    private static string FormatPrice(decimal value) =>
        $"${value:N2}";

    private static string FormatVolume(long vol) =>
        vol >= 1_000_000_000 ? $"{vol / 1_000_000_000.0:F1}B" :
        vol >= 100_000_000 ? $"{vol / 1_000_000.0:F0}M" :
        vol >= 1_000_000 ? $"{vol / 1_000_000.0:F1}M" :
        vol >= 1_000 ? $"{vol / 1_000.0:F0}K" : vol.ToString();

    private static string PnlClass(decimal value) =>
        value > 0 ? "tp-up" : value < 0 ? "tp-down" : "tp-flat";

    private static string RsiClass(decimal rsi) =>
        rsi >= 70 ? "tp-down" : rsi <= 30 ? "tp-up" : "tp-flat";

    private static string MomClass(decimal mom) =>
        mom > 0.1m ? "tp-up" : mom < -0.1m ? "tp-down" : "tp-flat";

    private static string StrengthClass(string str) => str switch
    {
        "Strong" => "tp-strength-strong",
        "Moderate" => "tp-strength-mod",
        _ => "tp-strength-weak"
    };

    private static string TruncateReason(string reason) =>
        reason.Length > 40 ? reason[..37] + "..." : reason;

    /// <summary>Extract short exit reason from the full reason string logged by PositionMonitor.</summary>
    private static string ExtractExitReason(string reason)
    {
        if (string.IsNullOrEmpty(reason)) return "—";
        // Match known exit types from PositionMonitor log messages
        if (reason.Contains("TRAILING STOP")) return "TRAIL";
        if (reason.Contains("STOP LOSS")) return "STOP";
        if (reason.Contains("PROFIT TARGET")) return "TARGET";
        if (reason.Contains("BREAKEVEN")) return "B/E";
        if (reason.Contains("REGIME EXIT")) return "REGIME";
        if (reason.Contains("OPPOSING")) return "OPPOSE";
        if (reason.Contains("TIME+WEAK")) return "TIME";
        if (reason.Contains("TIME+NOSIGNAL")) return "NOSIG";
        if (reason.Contains("TIME CAP")) return "CAP";
        return reason.Length > 8 ? reason[..8] : reason;
    }

    private static string FormatHoldTime(int seconds) =>
        seconds >= 3600 ? $"{seconds / 3600}h{seconds % 3600 / 60}m" :
        seconds >= 60 ? $"{seconds / 60}m" : $"{seconds}s";

    private record RoundTrip(string Ticker, bool IsLong, int Qty, decimal EntryPrice, decimal ExitPrice,
        decimal Pnl, DateTime ExitTime, int HoldSeconds, string EntrySource, decimal EntryScore, string ExitReason);

    private static List<RoundTrip> PairTrades(List<TradeDto> trades)
    {
        var result = new List<RoundTrip>();
        var open = new Dictionary<string, TradeDto>();
        var sorted = trades.Where(t => t.Status == "Filled").OrderBy(t => t.Timestamp).ToList();

        foreach (var t in sorted)
        {
            if (open.TryGetValue(t.Ticker, out var entry))
            {
                bool isLong = entry.Action == "BUY";
                int qty = entry.Quantity;
                decimal pnl = isLong
                    ? (t.Price - entry.Price) * qty
                    : (entry.Price - t.Price) * qty;
                int holdSec = (int)(t.Timestamp - entry.Timestamp).TotalSeconds;
                string entrySource = !string.IsNullOrEmpty(entry.Source) ? entry.Source : "—";
                string exitReason = ExtractExitReason(t.Reason);
                result.Add(new RoundTrip(t.Ticker, isLong, qty, entry.Price, t.Price, pnl, t.Timestamp, holdSec, entrySource, entry.Score, exitReason));
                open.Remove(t.Ticker);
            }
            else
            {
                open[t.Ticker] = t;
            }
        }
        result.Reverse(); // Show most recent first
        return result;
    }

    private static string HealthDotClass(string status) => status switch
    {
        "Live" => "tp-dot-live",
        "Stale" => "tp-dot-stale",
        "Delayed" => "tp-dot-delayed",
        _ => "tp-dot-offline"
    };

    private static string FormatAge(double sec) =>
        sec < 0 ? "N/A" : sec < 60 ? $"{sec:F0}s" : sec < 3600 ? $"{sec / 60:F0}m" : $"{sec / 3600:F1}h";

    public void Dispose() => _refreshTimer?.Dispose();
}

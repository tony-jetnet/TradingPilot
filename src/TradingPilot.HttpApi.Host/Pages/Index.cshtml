@page
@using Microsoft.AspNetCore.Mvc.Localization
@using TradingPilot.Localization
@using TradingPilot.Pages
@using Volo.Abp.AspNetCore.Mvc.UI.Theming
@using Volo.Abp.Ui.Branding
@model IndexModel
@inject IHtmlLocalizer<TradingPilotResource> L
@inject IBrandingProvider BrandingProvider
@inject ITheme Theme
@{
    Layout = Theme.GetEmptyLayout();
}

<div class="d-flex align-items-center" style="min-height: 100vh;">
    <div class="container">
        <div class="text-center">
            <h1>@BrandingProvider.AppName</h1>
            <p class="text-muted">Welcome to TradingPilot API</p>
            <a href="/swagger" class="btn btn-primary">Swagger UI</a>
        </div>
    </div>
</div>
